---
const { t } = Astro.props;
---

<section
  id="about"
  class="w-full h-full md:h-[650px] lg:h-[750px] relative before:bg-[url(/about-bg.webp)] before:bg-no-repeat before:-z-10 before:h-full before:bg-[bottom_right] md:before:bg-[bottom_right_-60px] before:bg-[clamp(20rem,2.222rem+88.889vw,25rem)_auto] md:before:bg-[400px_auto] lg:before:bg-[auto_700px] before:w-full before:absolute before:left-0 before:top-0 before:content-[''] after:bg-[#383838] after:-z-20 after:h-full after:w-full after:absolute after:left-0 after:top-0 after:content-[''] overflow-hidden"
>
  <div
    class="contenedor about flex flex-col justify-center w-full h-full gap-4 [animation-iteration-count:infinite] taos:translate-x-[-200px] delay-[200ms] duration-[500ms] taos:opacity-0"
    data-taos-offset="300"
  >
    <h2 class="text-acento text-3xl font-bold">{t.title}</h2>

    <p class="text-sm sm:text-base">{t.description1}</p>

    <p class="text-sm sm:text-base">{t.description2}</p>
    <div class=" stats-container w-full xl:w-3/4 grid grid-cols-1 min-[440px]:grid-cols-3 max-[440px]:gap-5 mx-auto max-[440px]:max-w-48 gap-2 lg:gap-5 xl:gap-12 !mt-10 justify-center text-center" id="stats-container">
      <div class="stat-item flex shrink-0 flex-col items-center gap-0 border-acento border rounded-md p-5 w-full">
        <span class="stat-number text-acento text-xl font-bold"
          >+<span class="counter " data-target="50">0</span
          > {t.item3year}</span
        >
        <span class="stat-label text-xs max-[440px]:text-sm ">{t.item3}</span>
      </div>
      

      <div class="stat-item flex shrink-0 flex-col items-center gap-0 border-acento border rounded-md p-5 w-full">
        <span class="stat-number text-acento text-xl font-bold"
          >+<span class="counter" data-target="100">0</span
          ></span
        >
        <span class="stat-label max-[440px]:text-sm  text-xs ">{t.item2}</span>
      </div>

      <div class="stat-item flex flex-col shrink-0 items-center gap-0 border-acento border rounded-md p-5 w-full">
        
        <span class="stat-number text-acento text-xl font-bold"
          >+<span class="counter" data-target="4500">0</span>m²</span
        >
        <span class="stat-label text-xs max-[440px]:text-sm ">{t.item1}</span>
      </div>
      
    </div>
  </div>
</section>

<style>
  #about {
    clip-path: polygon(0 0, 100% 0, 100% 100%, 0 95%);
  }

  .about {
    padding: 0 clamp(37.5rem, 44.643rem + -11.161vw, 31.25rem) 0 20px;
  }

  @media (width < 1024px) and (width >= 768px) {
    .about {
      padding: 0 360px 0 20px;
    }
  }

  @media (width < 768px) {
    .about {
      padding: 144px 20px clamp(27.5rem, 4.167rem + 116.667vw, 34.063rem) 20px;
    }
  }
</style>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const counters = document.querySelectorAll(".counter");
    const container = document.querySelector("#stats-container");

    const animateValue = (obj, start, end, duration) => {
      let startTimestamp = null;
      const step = (timestamp) => {
        if (!startTimestamp) startTimestamp = timestamp;
        const progress = Math.min((timestamp - startTimestamp) / duration, 1);

        const easeProgress = 1 - Math.pow(1 - progress, 3);
        obj.innerHTML = Math.floor(easeProgress * (end - start) + start);

        if (progress < 1) {
          window.requestAnimationFrame(step);
        } else {
          obj.innerHTML = end;
        }
      };
      window.requestAnimationFrame(step);
    };

    const observer = new IntersectionObserver(
      (entries, obs) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            // 1. El usuario llegó a la sección, animamos los números
            counters.forEach((counter) => {
              const target = parseInt(counter.getAttribute("data-target"), 10);
              animateValue(counter, 0, target, 2000);
            });

            obs.disconnect();
          }
        });
      },
      {
        threshold: 0.5,
      },
    );

    if (container) {
      observer.observe(container);
    }
  });
</script>
