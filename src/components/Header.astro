          class="hover:text-acento font-medium transition-all duration-300 ease-in-out max-[1024px]:py-6 max-[1024px]:border-b max-[1024px]:w-full max-[1024px]:border-claro"
          >{t.contacto}</a
        >
      </li>
    </ul>
